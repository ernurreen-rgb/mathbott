# Backend-only Caddy config for the Google Cloud VPS.
# Set BACKEND_DOMAIN=qazmath-api.35-225-92-22.sslip.io in the VPS env file.
# Caddy needs public ports 80 and 443 so it can issue and renew TLS certificates.

{$BACKEND_DOMAIN} {
    encode gzip zstd
    header {
        Content-Security-Policy "default-src 'none'; frame-ancestors 'none'; base-uri 'none'"
        Referrer-Policy "no-referrer"
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
    }
    reverse_proxy backend:8000
}
